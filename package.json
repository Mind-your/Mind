{
  "dependencies": {
    "fuse.js": "^7.1.0",
    "react-router-dom": "^7.8.2"
  },
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && ./mvnw spring-boot:run",
    "i:frontend": "cd frontend && npm install",
    "start:backend": "cd backend && mvnw.cmd spring-boot:run",
    "start:frontend": "npm run dev --prefix frontend",
    "start:email": "cd email-service && mvnw.cmd spring-boot:run -Dspring-boot.run.profiles=local",
    "dev": "concurrently --kill-others --names \"BACK,FRONT,EMAIL\" -c \"bgBlue.bold,bgMagenta.bold,bgYellow.bold\" \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:email\"",
    "reset:db": "node reset-db.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "mongodb": "^7.1.0"
  }
}
